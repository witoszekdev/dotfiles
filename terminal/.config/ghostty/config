font-family = "JetBrainsMono Nerd Font Mono"
adjust-cursor-thickness = 1
macos-option-as-alt = true

# Tabs and Windows
keybind = super+t=new_tab
keybind = super+n=new_window
keybind = super+enter=new_split:auto

# Closing logic
keybind = super+shift+w=close_surface
keybind = super+w=close_tab

# Word jumping (Option + Arrows)
keybind = alt+left=text:\x1bb
keybind = alt+right=text:\x1bf

# Window/Split Navigation (Command + Arrows)
keybind = super+left=goto_split:left
keybind = super+right=goto_split:right
keybind = super+up=goto_split:up
keybind = super+down=goto_split:down
keybind = super+shift+l=toggle_split_zoom

keybind = super+ctrl+left=resize_split:left,10
keybind = super+ctrl+right=resize_split:right,10
keybind = super+ctrl+up=resize_split:up,10
keybind = super+ctrl+down=resize_split:down,10
