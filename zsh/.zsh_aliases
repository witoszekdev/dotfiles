alias ni="npm install"
alias nid="npm install -D"
alias nr="npm run"
alias zshconfig="code ~/.zshrc"

# lsd shortcuts
alias ls='lsd'
alias l='ls -l'
alias la='ls -a'
alias lla='ls -la'

# Additional git aliases
alias gce='git commit --allow-empty'
alias gpf='git push --force-with-lease' # https://stackoverflow.com/a/37460330
checkout() {
    if [ -z "$1" ] ; then
        git checkout $(git branch | fzf | tr -d '[:space:]' | tr -d '^[*+]') $@
    else
        git checkout $@
    fi
}
alias gco='checkout'

# nnn
alias nnn='nnn -e'

# bat
alias cat='bat'

# zoxide
alias z='zoxide'

# kitty ssh
alias s="kitty +kitten ssh"

# Use NeoVim as vim
alias vim='nvim --listen /tmp/nvimsocket'
# alias vim='lvim --listen /tmp/nvimsocket'
# alias vim='lvim'
alias vimrc='vim ~/.config/nvim/init.vim'
alias v='vim --listen /tmp/nvimsocket'
export NVR_CMD="nvim"

# projects browser
projects() {
  cd ~/PROJECTS
  # search only git repositories or folders with README.md
  selected_folder=$(find . -maxdepth 3 \( -name ".git" -o -name "README.md" \) -not -path "*/node_modules/*" | sed -E "s/\/.git|\/README.md//g" | uniq | fzf)

  if [ -n "$selected_folder" ]; then
    cd $selected_folder
  fi
}
alias p='projects'

worktrees() {
  cd ~/worktrees

  # First, select project
  selected_project=$(find . -mindepth 1 -maxdepth 1 -type d | sed 's|^\./||' | sort | fzf --prompt "Select project: " --preview 'ls -la ~/worktrees/{}')

  if [ -z "$selected_project" ]; then
    return
  fi

  # Then, select worktree within that project
  selected_worktree=$(find "$selected_project" -mindepth 1 -maxdepth 1 -type d | sed "s|^$selected_project/||" | sort | fzf --prompt "Select worktree in $selected_project: " --preview "ls -la ~/worktrees/$selected_project/{}")

  if [ -n "$selected_worktree" ]; then
    cd "$selected_project/$selected_worktree"
  fi
}
alias w='worktrees'

# Simple worktree search (single step)
worktrees_simple() {
  cd ~/worktrees

  # Find all worktrees in ~/worktrees/<project>/<worktree> structure
  # Format as "project/worktree" for better visibility
  selected_folder=$(find . -mindepth 2 -maxdepth 2 -type d -not -path "*/node_modules/*" | sed 's|^\./||' | sort | fzf --delimiter '/' --with-nth 1,2 --preview 'ls -la ~/worktrees/{} 2>/dev/null')

  if [ -n "$selected_folder" ]; then
    cd "$selected_folder"
  fi
}
alias ww='worktrees_simple'

# copilot shell completion
eval "$(gh copilot alias -- zsh)"

# running jest
alias jb='./node_modules/.bin/jest'

# git worktree create
alias gwtc='python3 ~/dotfiles/scripts/git-worktree-create.py'
